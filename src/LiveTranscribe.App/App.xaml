<Application x:Class="LiveTranscribe.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LiveTranscribe.App"
             xmlns:views="clr-namespace:LiveTranscribe.App.Views"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Converters -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
            <views:LevelToScaleConverter x:Key="LevelToScale" />
            <views:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
            <views:NonEmptyToVisibilityConverter x:Key="NonEmptyToVisibility" />

            <!-- Palette -->
            <Color x:Key="AccentColor">#FF3B82F6</Color>
            <Color x:Key="SurfaceColor">#F21B1B22</Color>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="AccentSoftBrush" Color="#FF5B9BFF" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
            <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#FF26262F" />
            <SolidColorBrush x:Key="CardBrush" Color="#FF222230" />
            <SolidColorBrush x:Key="TextBrush" Color="#FFF2F2F5" />
            <SolidColorBrush x:Key="MutedBrush" Color="#FF9A9AA8" />
            <SolidColorBrush x:Key="RecordingBrush" Color="#FFEF4444" />
            <SolidColorBrush x:Key="BorderBrush" Color="#22FFFFFF" />
            <SolidColorBrush x:Key="FieldBrush" Color="#FF2C2C38" />

            <!-- Modern flat button -->
            <Style x:Key="ModernButton" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="Background" Value="{StaticResource FieldBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <!-- Modern text input -->
            <Style x:Key="ModernTextBox" TargetType="TextBox">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
                <Setter Property="Background" Value="{StaticResource FieldBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ScrollViewer x:Name="PART_ContentHost" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Apply modern look to all controls by default -->
            <Style TargetType="Button" BasedOn="{StaticResource ModernButton}" />
            <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}" />
            <Style TargetType="PasswordBox">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="Background" Value="{StaticResource FieldBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="8,6" />
            </Style>
            <Style TargetType="ComboBox">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="Background" Value="{StaticResource FieldBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                <Setter Property="Padding" Value="8,5" />
                <Setter Property="FontSize" Value="13" />
            </Style>
            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="Margin" Value="0,7,0,0" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
