<Window x:Class="LiveTranscribe.App.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Live Transcribe"
        SizeToContent="WidthAndHeight"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True">

    <Window.Resources>
        <!-- Equalizer animation for the waveform bars + accent glow while recording -->
        <Storyboard x:Key="WaveAnim" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="Bar0" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="0.35" To="1.0" Duration="0:0:0.45" />
            <DoubleAnimation Storyboard.TargetName="Bar1" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="0.6" To="0.3" Duration="0:0:0.5" BeginTime="0:0:0.08" />
            <DoubleAnimation Storyboard.TargetName="Bar2" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="0.4" To="1.0" Duration="0:0:0.4" BeginTime="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="Bar3" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="0.8" To="0.35" Duration="0:0:0.55" BeginTime="0:0:0.04" />
            <DoubleAnimation Storyboard.TargetName="Bar4" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="0.45" To="0.95" Duration="0:0:0.48" BeginTime="0:0:0.12" />
            <ColorAnimation Storyboard.TargetName="PillGlow" Storyboard.TargetProperty="Color"
                            To="#EF4444" Duration="0:0:0.6" />
            <DoubleAnimation Storyboard.TargetName="PillGlow" Storyboard.TargetProperty="Opacity"
                             From="0.4" To="0.7" Duration="0:0:0.6" />
        </Storyboard>

        <Style x:Key="WaveBar" TargetType="Rectangle">
            <Setter Property="Width" Value="3" />
            <Setter Property="Height" Value="18" />
            <Setter Property="RadiusX" Value="1.5" />
            <Setter Property="RadiusY" Value="1.5" />
            <Setter Property="Margin" Value="1.5,0" />
            <Setter Property="Fill" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border x:Name="Pill" CornerRadius="20" Padding="8,7"
            MouseLeftButtonDown="OnDragHandle">
        <Border.Background>
            <SolidColorBrush Color="{StaticResource SurfaceColor}" />
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect x:Name="PillGlow" BlurRadius="22" ShadowDepth="0" Opacity="0.4" Color="#000000" />
        </Border.Effect>

        <StackPanel>
            <!-- Compact row: mic, status, waveform, expander -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" MinWidth="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Mic / record toggle -->
                <Button Grid.Column="0" Width="38" Height="38" Command="{Binding ToggleRecordingCommand}"
                        Cursor="Hand" BorderThickness="0" Background="Transparent">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse x:Name="Disc" Fill="{StaticResource AccentBrush}" />
                                <Path x:Name="Icon" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M8,1 C6.9,1 6,1.9 6,3 L6,8 C6,9.1 6.9,10 8,10 C9.1,10 10,9.1 10,8 L10,3 C10,1.9 9.1,1 8,1 Z M12,8 C12,10.2 10.2,12 8,12 C5.8,12 4,10.2 4,8 L2.5,8 C2.5,10.7 4.5,12.9 7,13.4 L7,15.5 L9,15.5 L9,13.4 C11.5,12.9 13.5,10.7 13.5,8 Z"
                                      Stretch="Uniform" Width="16" Height="16" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                    <Setter TargetName="Disc" Property="Fill" Value="{StaticResource RecordingBrush}" />
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Disc" Property="Opacity" Value="0.88" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Status text -->
                <StackPanel Grid.Column="1" Margin="10,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextBrush}"
                               FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!-- Waveform (the level meter), reacts to mic level + animates while recording -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0"
                            Height="22">
                    <StackPanel.RenderTransform>
                        <ScaleTransform ScaleY="{Binding Level, Converter={StaticResource LevelToScale}}" />
                    </StackPanel.RenderTransform>
                    <StackPanel.RenderTransformOrigin>0.5,0.5</StackPanel.RenderTransformOrigin>
                    <Rectangle x:Name="Bar0" Style="{StaticResource WaveBar}"><Rectangle.RenderTransform><ScaleTransform ScaleY="0.4" /></Rectangle.RenderTransform></Rectangle>
                    <Rectangle x:Name="Bar1" Style="{StaticResource WaveBar}"><Rectangle.RenderTransform><ScaleTransform ScaleY="0.4" /></Rectangle.RenderTransform></Rectangle>
                    <Rectangle x:Name="Bar2" Style="{StaticResource WaveBar}"><Rectangle.RenderTransform><ScaleTransform ScaleY="0.4" /></Rectangle.RenderTransform></Rectangle>
                    <Rectangle x:Name="Bar3" Style="{StaticResource WaveBar}"><Rectangle.RenderTransform><ScaleTransform ScaleY="0.4" /></Rectangle.RenderTransform></Rectangle>
                    <Rectangle x:Name="Bar4" Style="{StaticResource WaveBar}"><Rectangle.RenderTransform><ScaleTransform ScaleY="0.4" /></Rectangle.RenderTransform></Rectangle>
                </StackPanel>

                <!-- Expander chevron -->
                <ToggleButton Grid.Column="3" Width="24" Height="24" Cursor="Hand"
                              IsChecked="{Binding IsExpanded, Mode=TwoWay}" Background="Transparent"
                              ToolTip="Optionen">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Background="Transparent">
                                <Path x:Name="Chevron" Data="M 0 0 L 5 5 L 10 0" Stroke="{StaticResource MutedBrush}"
                                      StrokeThickness="1.6" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      RenderTransformOrigin="0.5,0.5" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Chevron" Property="RenderTransform">
                                        <Setter.Value>
                                            <RotateTransform Angle="180" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Chevron" Property="Stroke" Value="{StaticResource TextBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
            </Grid>

            <!-- Live transcript (only while there is partial text) -->
            <Border Margin="2,8,2,0" Background="#33000000" CornerRadius="10" Padding="10,7"
                    MaxWidth="320"
                    Visibility="{Binding LivePartialText, Converter={StaticResource NonEmptyToVisibility}}">
                <TextBlock Text="{Binding LivePartialText}" Foreground="{StaticResource TextBrush}"
                           FontSize="13" TextWrapping="Wrap" MaxHeight="120" />
            </Border>

            <!-- Expandable options -->
            <StackPanel Margin="2,8,2,2"
                        Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" Margin="0,0,4,0" ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}" />
                    <ComboBox Grid.Column="1" Margin="4,0,4,0" ItemsSource="{Binding Tones}" SelectedItem="{Binding SelectedTone}"
                              IsEnabled="{Binding IsToneEnabled}" />
                    <Button Grid.Column="2" Content="⚙" FontSize="15" Width="34" Height="30" Padding="0"
                            Click="OnSettingsClick" Background="Transparent" Foreground="{StaticResource MutedBrush}"
                            BorderThickness="0" Cursor="Hand" ToolTip="Einstellungen" />
                </Grid>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
