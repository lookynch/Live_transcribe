<Window x:Class="LiveTranscribe.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen — Live Transcribe"
        Width="600" Height="720" WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="Section">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,18,0,8" />
        </Style>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Margin" Value="0,6,0,2" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Transkription -->
                <TextBlock Text="Transkription" Style="{StaticResource Section}" />
                <TextBlock Text="Whisper-Modell (lokal)" Style="{StaticResource Label}" />
                <ComboBox ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel}" />
                <TextBlock Text="Sprache" Style="{StaticResource Label}" />
                <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}" />
                <TextBlock Text="Nach Aufnahme" Style="{StaticResource Label}" />
                <ComboBox ItemsSource="{Binding Behaviors}" SelectedItem="{Binding SelectedBehavior}" />

                <!-- OpenAI -->
                <TextBlock Text="OpenAI-Textoptimierung" Style="{StaticResource Section}" />
                <TextBlock Text="Audio wird niemals an OpenAI gesendet — nur der lokal transkribierte Text, und nur wenn ein Optimierungsmodus gewählt ist."
                           TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="11" />
                <TextBlock Text="OpenAI-Modell" Style="{StaticResource Label}" />
                <TextBox Text="{Binding OpenAiModel}" />
                <CheckBox Content="Bei OpenAI-Fehler Rohtext einfügen" IsChecked="{Binding FallbackToRaw}" />
                <TextBlock Text="Eigene Anweisung (für Modus „Eigene Anweisung“)" Style="{StaticResource Label}" />
                <TextBox Text="{Binding CustomInstruction}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48" />

                <TextBlock Text="API-Key" Style="{StaticResource Label}" />
                <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11"
                           Text="{Binding HasApiKey, StringFormat='Status: {0}'}" />
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="ApiKeyBox" Grid.Column="0" />
                    <Button Grid.Column="1" Content="Speichern" Margin="8,0,0,0" Width="90" Click="OnSaveApiKey" />
                    <Button Grid.Column="2" Content="Löschen" Margin="8,0,0,0" Width="80" Command="{Binding ClearApiKeyCommand}" />
                </Grid>

                <!-- Start -->
                <TextBlock Text="Start" Style="{StaticResource Section}" />
                <CheckBox Content="Mit Windows starten (Autostart)" IsChecked="{Binding AutostartEnabled}" />

                <!-- Updates -->
                <TextBlock Text="Updates" Style="{StaticResource Section}" />
                <TextBlock Foreground="{StaticResource TextBrush}" Text="{Binding CurrentVersion, StringFormat='Aktuelle Version: {0}'}" />
                <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11" Text="{Binding UpdateSource, StringFormat='Quelle: {0}'}" TextWrapping="Wrap" />
                <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11" Text="{Binding LastCheck, StringFormat='Letzte Prüfung: {0}'}" />
                <CheckBox Content="Beim Start automatisch nach Updates suchen" IsChecked="{Binding CheckOnStartup}" />
                <CheckBox Content="Pre-Releases erlauben" IsChecked="{Binding AllowPrerelease}" />
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Nach Updates suchen" Width="160" Command="{Binding CheckForUpdatesCommand}" />
                    <Button Content="Update installieren" Width="160" Margin="8,0,0,0"
                            Command="{Binding InstallUpdateCommand}"
                            Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibility}}"
                            Background="{StaticResource AccentBrush}" Foreground="White" />
                </StackPanel>
                <TextBlock Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" Text="{Binding UpdateStatus}" />
                <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"
                           Text="{Binding ReleaseNotes}"
                           Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibility}}" />

                <!-- Deinstallation -->
                <TextBlock Text="Bei Deinstallation" Style="{StaticResource Section}" />
                <TextBlock Text="Diese Auswahl wird beim Deinstallieren angewendet (kein Dialog möglich)."
                           Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap" />
                <CheckBox Content="Einstellungen löschen" IsChecked="{Binding DeleteSettingsOnUninstall}" />
                <CheckBox Content="Heruntergeladene Modelle löschen" IsChecked="{Binding DeleteModelsOnUninstall}" />
                <CheckBox Content="Gespeicherten API-Key löschen" IsChecked="{Binding DeleteApiKeyOnUninstall}" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Schließen" Width="120" Click="OnClose"
                    Background="{StaticResource AccentBrush}" Foreground="White" />
        </StackPanel>
    </Grid>
</Window>
