<Window x:Class="LiveTranscribe.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LiveTranscribe.App.Views"
        Title="Einstellungen — Live Transcribe"
        Width="640" Height="760" WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">
    <Window.Resources>
        <Style TargetType="Border" x:Key="Card">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
        <Style TargetType="TextBlock" x:Key="Section">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,8,0,3" />
        </Style>
        <Style TargetType="TextBlock" x:Key="Hint">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}" />
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Einstellungen" Foreground="{StaticResource TextBrush}"
                   FontSize="22" FontWeight="Bold" Margin="2,0,0,16" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <StackPanel>
                <!-- Transkription -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Transkription" Style="{StaticResource Section}" />
                        <TextBlock Text="Whisper-Modell (lokal)" Style="{StaticResource Label}" />
                        <ComboBox ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel}" />
                        <TextBlock Text="Sprache" Style="{StaticResource Label}" />
                        <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}" />
                        <TextBlock Text="Nach Aufnahme" Style="{StaticResource Label}" />
                        <ComboBox ItemsSource="{Binding Behaviors}" SelectedItem="{Binding SelectedBehavior}" />
                        <CheckBox Content="Live-Vorschau während der Aufnahme (Tiny-Modell)" IsChecked="{Binding LiveEnabled}" />
                    </StackPanel>
                </Border>

                <!-- Tastenkürzel -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Tastenkürzel" Style="{StaticResource Section}" />
                        <TextBlock Text="Auf eine Schaltfläche klicken und dann die gewünschte Tastenkombination drücken (Esc bricht ab)."
                                   Style="{StaticResource Hint}" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Push-to-Talk (gedrückt halten)" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" />
                            <views:HotkeyBox Grid.Row="0" Grid.Column="1" Margin="0,4" Hotkey="{Binding PushToTalkHotkey, Mode=TwoWay}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Aufnahme starten/stoppen" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" />
                            <views:HotkeyBox Grid.Row="1" Grid.Column="1" Margin="0,4" Hotkey="{Binding StartStopHotkey, Mode=TwoWay}" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Overlay ein-/ausblenden" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" />
                            <views:HotkeyBox Grid.Row="2" Grid.Column="1" Margin="0,4" Hotkey="{Binding ToggleOverlayHotkey, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- OpenAI -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="OpenAI-Textoptimierung" Style="{StaticResource Section}" />
                        <TextBlock Text="Audio wird niemals an OpenAI gesendet — nur der lokal transkribierte Text, und nur wenn ein Optimierungsmodus gewählt ist."
                                   Style="{StaticResource Hint}" />
                        <TextBlock Text="OpenAI-Modell" Style="{StaticResource Label}" />
                        <TextBox Text="{Binding OpenAiModel}" />
                        <CheckBox Content="Bei OpenAI-Fehler Rohtext einfügen" IsChecked="{Binding FallbackToRaw}" />
                        <TextBlock Text="Eigene Anweisung (für Modus „Eigene Anweisung“)" Style="{StaticResource Label}" />
                        <TextBox Text="{Binding CustomInstruction}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48" />

                        <TextBlock Text="API-Key" Style="{StaticResource Label}" />
                        <TextBlock Style="{StaticResource Hint}" Text="{Binding HasApiKey, StringFormat='Status: {0}'}" />
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="ApiKeyBox" Grid.Column="0" />
                            <Button Grid.Column="1" Content="Speichern" Margin="8,0,0,0" Width="90" Click="OnSaveApiKey" />
                            <Button Grid.Column="2" Content="Löschen" Margin="8,0,0,0" Width="80" Command="{Binding ClearApiKeyCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Start -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Start" Style="{StaticResource Section}" />
                        <CheckBox Content="Mit Windows starten (Autostart)" IsChecked="{Binding AutostartEnabled}" />
                    </StackPanel>
                </Border>

                <!-- Updates -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Updates" Style="{StaticResource Section}" />
                        <TextBlock Foreground="{StaticResource TextBrush}" Text="{Binding CurrentVersion, StringFormat='Aktuelle Version: {0}'}" />
                        <TextBlock Style="{StaticResource Hint}" Margin="0,4,0,0" Text="{Binding UpdateSource, StringFormat='Quelle: {0}'}" />
                        <TextBlock Style="{StaticResource Hint}" Text="{Binding LastCheck, StringFormat='Letzte Prüfung: {0}'}" />
                        <CheckBox Content="Beim Start automatisch nach Updates suchen" IsChecked="{Binding CheckOnStartup}" />
                        <CheckBox Content="Pre-Releases erlauben" IsChecked="{Binding AllowPrerelease}" />
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="Nach Updates suchen" Width="160" Command="{Binding CheckForUpdatesCommand}" />
                            <Button Content="Update installieren" Width="160" Margin="8,0,0,0"
                                    Style="{StaticResource AccentButton}"
                                    Command="{Binding InstallUpdateCommand}"
                                    Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource Hint}" Margin="0,8,0,0" Text="{Binding UpdateStatus}" />
                        <TextBlock Style="{StaticResource Hint}" Margin="0,6,0,0"
                                   Text="{Binding ReleaseNotes}"
                                   Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>
                </Border>

                <!-- Deinstallation -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Bei Deinstallation" Style="{StaticResource Section}" />
                        <TextBlock Text="Diese Auswahl wird beim Deinstallieren angewendet (kein Dialog möglich)."
                                   Style="{StaticResource Hint}" />
                        <CheckBox Content="Einstellungen löschen" IsChecked="{Binding DeleteSettingsOnUninstall}" />
                        <CheckBox Content="Heruntergeladene Modelle löschen" IsChecked="{Binding DeleteModelsOnUninstall}" />
                        <CheckBox Content="Gespeicherten API-Key löschen" IsChecked="{Binding DeleteApiKeyOnUninstall}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Schließen" Width="120" Style="{StaticResource AccentButton}" Click="OnClose" />
        </StackPanel>
    </Grid>
</Window>
